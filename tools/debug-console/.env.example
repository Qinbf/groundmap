# 主管理台 API 入口（web/ 启动的端口，默认 3006）
KB_API_BASE=http://localhost:3006

# 各模型 provider 的 API key（按需配置；未填则该 provider 在 UI 中灰显）
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OpenAI 兼容端点的自定义 baseURL（如 Moonshot / Qwen / 自建网关）。空 = 用 OpenAI 官方
OPENAI_BASE_URL=

# Claude Code / Codex CLI 二进制名（PATH 中可执行即可）
CLAUDE_CODE_BIN=claude
CODEX_BIN=codex
