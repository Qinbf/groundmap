{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Write(raw/**)",
      "Edit(raw/**)",
      "Write(my_thoughts/**)",
      "Edit(my_thoughts/**)",
      "Write(workspaces/*/raw/**)",
      "Edit(workspaces/*/raw/**)",
      "Write(workspaces/*/my_thoughts/**)",
      "Edit(workspaces/*/my_thoughts/**)",
      "Write(**/raw/**)",
      "Edit(**/raw/**)",
      "Write(**/my_thoughts/**)",
      "Edit(**/my_thoughts/**)",
      "Bash(rm raw/**)",
      "Bash(rm -rf raw*)",
      "Bash(rm -r raw*)",
      "Bash(rm -f raw*)",
      "Bash(rm my_thoughts/**)",
      "Bash(rm -rf my_thoughts*)",
      "Bash(rm -r my_thoughts*)",
      "Bash(rm -f my_thoughts*)",
      "Bash(mv raw/**)",
      "Bash(mv my_thoughts/**)",
      "Bash(rm workspaces/*/raw/**)",
      "Bash(rm -rf workspaces/*/raw*)",
      "Bash(rm -r workspaces/*/raw*)",
      "Bash(rm -f workspaces/*/raw*)",
      "Bash(rm workspaces/*/my_thoughts/**)",
      "Bash(rm -rf workspaces/*/my_thoughts*)",
      "Bash(rm -r workspaces/*/my_thoughts*)",
      "Bash(rm -f workspaces/*/my_thoughts*)",
      "Bash(mv workspaces/*/raw/**)",
      "Bash(mv workspaces/*/my_thoughts/**)"
    ],
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(python scripts/k.py *)",
      "Bash(python scripts/convert.py *)",
      "Bash(python -m scripts.k *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(head *)",
      "Bash(tail *)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git rm *)",
      "Bash(git mv *)"
    ]
  }
}
