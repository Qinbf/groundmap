# GroundMap Web 管理台 — 环境变量（全部可选）。
# 本管理台只读写 markdown + 调 k.py，【不调用任何 LLM，因此不需要任何 API key】。
# 本地使用：cp .env.example .env.local（.env*.local 已被 .gitignore 忽略）

# 数据根：包含 workspaces/ 的目录。未设 = 引擎仓库自身（数据与代码同库，多主题模式）。
# 跨独立项目复用引擎时指向该项目的数据根，详见 README「Reusing one engine across independent projects」。
KB_ROOT=

# 启动时的初始/默认 workspace（界面顶栏切换器可随时改、写 cookie 优先）。未设 = 自动选用。
KB_WORKSPACE=

# k.py 子进程使用的 Python 解释器。未设 = 用 PATH 中的 "python"。
KB_PY=

# 顶栏「查询控制台」入口链接（独立子项目 tools/debug-console，默认端口 3100）。
# 设为空字符串可隐藏该入口。
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3100
